@namespace DojoBlazor.Components

<div class="p-4 border-b border-border bg-white/80">
    <div class="flex items-center justify-between gap-3">
        <div class="flex items-center gap-3">
            <div class="h-10 w-10 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xs font-bold">AI</div>
            <div class="text-left">
                <div class="text-sm font-semibold text-foreground">Copilot Chat</div>
                <div class="text-xs text-muted-foreground">Right panel assistant</div>
            </div>
        </div>
        <div class="flex items-center gap-2">
            <span class="text-[10px] uppercase tracking-wide text-muted-foreground">Preview</span>
            <button class="h-8 w-8 rounded-full border border-border bg-white text-muted-foreground hover:text-foreground hover:bg-muted/50 flex items-center justify-center transition" type="button">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <circle cx="5" cy="12" r="2"></circle>
                    <circle cx="12" cy="12" r="2"></circle>
                    <circle cx="19" cy="12" r="2"></circle>
                </svg>
            </button>
        </div>
    </div>
</div>
