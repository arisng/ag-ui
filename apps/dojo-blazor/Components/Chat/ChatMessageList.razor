@namespace DojoBlazor.Components

<div class="flex-1 min-h-0 overflow-y-auto p-4 space-y-4 bg-muted/10">
    <div class="text-[10px] uppercase tracking-[0.3em] text-muted-foreground text-center">Today</div>
    <div class="space-y-4">
        @foreach (var message in Messages)
        {
            <div class="flex items-start gap-3 @(message.IsUser ? "flex-row-reverse" : string.Empty)">
                <div class="h-8 w-8 rounded-full @(message.IsUser ? "bg-muted text-muted-foreground" : "bg-primary/10 text-primary") flex-shrink-0 flex items-center justify-center text-xs font-bold mt-1">
                    @message.Avatar
                </div>
                <div class="max-w-[85%] space-y-1 @(message.IsUser ? "text-right" : string.Empty)">
                    <div class="@(message.IsUser ? "bg-primary text-primary-foreground rounded-tr-none" : "bg-white border border-border rounded-tl-none") p-3 rounded-lg text-sm shadow-sm">
                        @message.Content
                    </div>
                    <div class="text-[10px] text-muted-foreground">@message.Time • @message.Role</div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private readonly List<ChatMessage> Messages = new()
    {
        new("AI", "System", "Hi 👋 I can help you explore the Dojo demos. Pick a feature and ask away.", "09:41", false),
        new("U", "You", "Show me how to stream tool output.", "09:42", true),
        new("AI", "Assistant", "Great choice. Select “Backend Tool Rendering” to preview streaming tools and UI updates.", "09:43", false),
    };

    private sealed record ChatMessage(string Avatar, string Role, string Content, string Time, bool IsUser);
}
